# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ==========================================
# API Proxy Security Configuration
# ==========================================

# 1. Set a proxy password to prevent unauthorized access.
# If this is set, your API clients MUST use this password as their "API Key".
PROXY_PASSWORD=

# 2. Add your REAL API Keys here.
# The server will automatically inject these into the requests to the providers.
# This prevents your real API keys from ever being exposed to the client or network.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
